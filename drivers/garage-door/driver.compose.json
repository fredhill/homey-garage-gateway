{
  "name": {
    "en": "Garage Door"
  },
  "class": "garagedoor",
  "capabilities": ["door_status", "garagedoor_closed"],
  "capabilitiesOptions": {
    "garagedoor_closed": {
      "title": { "en": "Position" }
    },
    "measure_temperature": {
      "title": { "en": "Garage Temperature" }
    },
    "measure_battery": {
      "title": { "en": "Sensor Battery" }
    }
  },
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "/drivers/garage-door/assets/images/small.png",
    "large": "/drivers/garage-door/assets/images/large.png"
  },
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "id": "left_open_warning",
      "type": "number",
      "label": { "en": "Left-open warning (minutes)" },
      "value": 20,
      "min": 1,
      "max": 240,
      "hint": {
        "en": "Fire the 'left open' trigger after the door has been open this long."
      }
    }
  ]
}

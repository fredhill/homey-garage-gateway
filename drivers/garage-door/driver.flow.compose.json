      "args": [
        {
          "name": "device",
          "type": "device",
          "placeholder": { "en": "Which door?" },
          "filter": "driver_id=garage-door"
        }
      ],
      "tokens": [
        {
          "name": "door_name",
          "type": "string",
          "title": { "en": "Door name" },
          "example": { "en": "Garage Door" }
        }
      ]
    },
    {
      "id": "door_left_open",
